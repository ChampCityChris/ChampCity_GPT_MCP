CHAMPCITY_GPT_ALLOWED_ROOTS=C:\Users\<you>\Projects\<project>
CHAMPCITY_GPT_PUBLIC_BASE_URL=https://mcp.example.com
CHAMPCITY_GPT_WRITE_MODE=off
CHAMPCITY_GPT_ACCESS_TOKEN_TTL_SECONDS=7200
CHAMPCITY_GPT_REFRESH_TOKEN_TTL_SECONDS=2592000

# Optional local development defaults.
CHAMPCITY_GPT_TRANSPORT=http
CHAMPCITY_GPT_HTTP_HOST=127.0.0.1
CHAMPCITY_GPT_HTTP_PORT=3333
CHAMPCITY_GPT_REQUIRE_GIT_ROOT=true
CHAMPCITY_GPT_ALLOW_NONLOCAL_HTTP=false
CHAMPCITY_GPT_ALLOW_UNAUTH_LOCAL_HTTP=false
