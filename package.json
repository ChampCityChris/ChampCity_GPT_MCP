{
  "name": "champcity-gpt",
  "version": "0.1.0",
  "description": "ChatGPT-compatible local MCP launcher with allowlisted project roots, OAuth, and audited file tools.",
  "type": "module",
  "main": "dist/electron/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/<owner>/<repo>.git"
  },
  "bin": {
    "champcity-gpt-mcp": "./dist/src/index.js"
  },
  "scripts": {
    "mcp:build": "tsc -p tsconfig.json",
    "build": "npm run mcp:build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "check:public": "powershell -ExecutionPolicy Bypass -File ./scripts/check-publication-clean.ps1",
    "check:release": "powershell -ExecutionPolicy Bypass -File ./scripts/check-release-clean.ps1",
    "app:build": "npm run mcp:build",
    "app:dev": "npm run app:build && electron .",
    "app:package": "npm run app:build && electron-builder --win portable --config electron-builder.json",
    "app:dist": "npm run app:build && electron-builder --win portable --config electron-builder.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "diff": "^9.0.0",
    "picomatch": "^4.0.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/picomatch": "^3.0.2",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.10.0"
  }
}
